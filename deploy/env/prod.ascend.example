ENV_PROFILE=prod.ascend
RELEASE_MANIFEST_PATH=/app/release.json
APP_PORT=18300
APP_DATA_DIR=/app/runtime
APP_MODEL_DIR=/app/models
APP_PUBLIC_URL=http://127.0.0.1:18300
HOST_RUNTIME_DIR=/opt/momentseek/runtime
HOST_MODEL_DIR=/opt/momentseek/models
NPU_ENABLED=true
NPU_DEVICE_ID=0
HOST_NPU_DEVICE_ID=2
CUDA_ENABLED=false
INDEXER_MODE=daemon
NPU_WORKER_MODE=isolated
INDEXER_IDLE_TIMEOUT_SECONDS=0
ASCEND_VISIBLE_DEVICES=2
ASCEND_RT_VISIBLE_DEVICES=2
TORCH_DEVICE_BACKEND_AUTOLOAD=0
OPENBLAS_NUM_THREADS=8
OPENBLAS_DEFAULT_NUM_THREADS=8
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
NUMEXPR_NUM_THREADS=8
BLIS_NUM_THREADS=8
TOKENIZERS_PARALLELISM=false
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=/app/models/ViT-B-32.openai.bin
VISUAL_MODEL=siglip2-so400m-384
VISUAL_HF_CACHE_DIR=/app/models/hf-cache
VISUAL_SAMPLE_FPS=5.0
VISUAL_SEGMENT_SECONDS=5.0
VISUAL_BATCH_SIZE=32
FACE_MODEL=buffalo_l
FACE_SAMPLE_FPS=1.0
FACE_PROVIDER=cann
FACE_ORT_INTRA_OP_THREADS=8
FACE_ORT_INTER_OP_THREADS=1
ASR_ENGINE=funasr
ASR_MODEL=turbo
ASR_ZH_MODEL=iic/SenseVoiceSmall
ASR_DEVICE=auto
ASR_LANGUAGE=zh
ASR_MODEL_LOCAL_FILES_ONLY=true
ASR_SEMANTIC_ENABLED=true
ASR_SEMANTIC_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
ASR_SEMANTIC_DEVICE=cpu
ASR_SEMANTIC_LOCAL_FILES_ONLY=true
OCR_ENGINE=rapidocr_acl
# PP-OCRv6 executes as precompiled OM models through the ACL runtime.
OCR_DEVICE=npu
OCR_ACL_MODEL_DIR=rapidocr/ascend/910b4-cann9-profile
OCR_VERSION=PP-OCRv6
OCR_DET_LANG=ch
OCR_REC_LANG=ch
OCR_MODEL_TYPE=small
OCR_SAMPLE_FPS=0.5
OCR_SEMANTIC_ENABLED=true
MODEL_MANIFEST=deploy/models/ascend-prod.models.json
ORCHESTRATION_ENABLED=false
ORCHESTRATION_CONFIG_PATH=deploy/orchestration/qwen35-vllm.json
ORCHESTRATION_PROFILE=qwen35-unified
ORCHESTRATION_FAIL_OPEN=true
ORCHESTRATION_TRACE_ENABLED=true
ORCHESTRATION_TRACE_PATH=/app/runtime/orchestration-traces.jsonl
QWEN35_VLLM_BASE_URL=http://127.0.0.1:18081/v1
QWEN35_PLANNER_MODEL=qwen3.5-4b
QWEN35_RERANKER_MODEL=qwen3.5-4b
