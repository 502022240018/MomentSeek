APP_PORT=8300
APP_DATA_DIR=/app/runtime
APP_MODEL_DIR=/app/models
# Change this to http://SERVER_IP:APP_PORT on a remote server.
APP_PUBLIC_URL=http://127.0.0.1:8300

# NPU is only touched by indexing subprocesses. Keep disabled until a card is approved.
NPU_ENABLED=false
NPU_DEVICE_ID=7
MODEL_IDLE_POLICY=process_exit

CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=/app/models/ViT-B-32.openai.bin
VISUAL_SAMPLE_FPS=1.0
VISUAL_SEGMENT_SECONDS=5.0
VISUAL_BATCH_SIZE=32

FACE_MODEL=buffalo_l
FACE_SAMPLE_FPS=2.0
FACE_PROVIDER=cpu

ASR_ENGINE=whisper
ASR_MODEL=tiny
ASR_DEVICE=cpu
