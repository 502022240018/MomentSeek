ENV_PROFILE=dev.cpu
APP_PORT=8000
APP_DATA_DIR=runtime
APP_MODEL_DIR=models
APP_PUBLIC_URL=http://127.0.0.1:8000
NPU_ENABLED=false
CUDA_ENABLED=false
MODEL_IDLE_POLICY=process_exit
INDEXER_MODE=subprocess
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=openai
VISUAL_MODEL=chinese-clip-vit-b16
VISUAL_HF_CACHE_DIR=models/hf-cache
VISUAL_SAMPLE_FPS=1.0
VISUAL_SEGMENT_SECONDS=5.0
VISUAL_SEGMENT_STRATEGY=fixed
VISUAL_MIN_SEGMENT_SECONDS=0.8
VISUAL_MAX_SEGMENT_SECONDS=8.0
VISUAL_SHOT_DETECTOR=simple
VISUAL_SHOT_THRESHOLD=0.20
VISUAL_BATCH_SIZE=8
FACE_MODEL=buffalo_l
FACE_SAMPLE_FPS=1.0
FACE_PROVIDER=cpu
ASR_ENGINE=auto
ASR_MODEL=turbo
ASR_ZH_MODEL=iic/SenseVoiceSmall
ASR_DEVICE=cpu
ASR_LANGUAGE=auto
ASR_MODEL_LOCAL_FILES_ONLY=true
ASR_SEMANTIC_ENABLED=true
ASR_SEMANTIC_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
ASR_SEMANTIC_DEVICE=cpu
ASR_SEMANTIC_LOCAL_FILES_ONLY=true
OCR_ENGINE=rapidocr
OCR_DEVICE=cpu
# PP-OCRv6 Chinese detection/recognition is the CPU/CUDA default.
# On Ascend NPU set OCR_VERSION=PP-OCRv4 / OCR_DET_LANG=en / OCR_REC_LANG=en
# (PP-OCRv6 attaches to CANN but returns empty results there).
OCR_VERSION=PP-OCRv6
OCR_DET_LANG=ch
OCR_REC_LANG=ch
OCR_SAMPLE_FPS=0.05
OCR_SEMANTIC_ENABLED=true
MODEL_MANIFEST=deploy/models/dev-full.models.json
