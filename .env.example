APP_PORT=8300
APP_DATA_DIR=/app/runtime
APP_MODEL_DIR=/app/models
# Change this to http://SERVER_IP:APP_PORT on a remote server.
APP_PUBLIC_URL=http://127.0.0.1:8300

# NPU is only touched by indexing subprocesses. Keep disabled until a card is approved.
NPU_ENABLED=false
NPU_DEVICE_ID=7
CUDA_ENABLED=false
MODEL_IDLE_POLICY=process_exit

CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=/app/models/ViT-B-32.openai.bin
VISUAL_SAMPLE_FPS=5.0
VISUAL_SEGMENT_SECONDS=5.0
VISUAL_BATCH_SIZE=32

FACE_MODEL=buffalo_l
FACE_SAMPLE_FPS=2.0
FACE_PROVIDER=cpu

# auto = prefer FunASR/Paraformer for Chinese, fall back to Whisper if unavailable.
ASR_ENGINE=auto
ASR_MODEL=small
# FunASR model id used when ASR_ENGINE=auto/funasr (Whisper ignores this).
ASR_ZH_MODEL=paraformer-zh
# auto = CUDA when CUDA_ENABLED, else Ascend NPU when NPU_ENABLED (torch_npu), else CPU.
ASR_DEVICE=auto
ASR_LANGUAGE=zh
ASR_SEMANTIC_ENABLED=true
ASR_SEMANTIC_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Keep semantic text embeddings on CPU unless you have explicitly validated CUDA/NPU.
ASR_SEMANTIC_DEVICE=cpu
ASR_SEMANTIC_BATCH_SIZE=32
# true = do not download during indexing/search; pre-cache or mount the model first.
ASR_SEMANTIC_LOCAL_FILES_ONLY=true
